//@version=6
indicator("Market Structure Zigzag", overlay=true, max_lines_count=500)

// 显式设置历史缓冲区大小，防止超出限制
max_bars_back(time, 500)
max_bars_back(high, 500)
max_bars_back(low, 500)

// ============================================================================
// 输入设置
// ============================================================================

grp_st = "短期结构"
show_st = input.bool(true, "显示短期结构", group=grp_st)
st_color = input.color(color.new(color.green, 0), "短期颜色", group=grp_st)
st_width = input.int(2, "短期线宽", minval=1, maxval=10, group=grp_st)
st_style = input.string("实线", "短期线型", options=["实线", "虚线", "点线"], group=grp_st)

grp_mt = "中期结构"
show_mt = input.bool(true, "显示中期结构", group=grp_mt)
mt_color = input.color(color.new(color.blue, 0), "中期颜色", group=grp_mt)
mt_width = input.int(2, "中期线宽", minval=1, maxval=10, group=grp_mt)
mt_style = input.string("实线", "中期线型", options=["实线", "虚线", "点线"], group=grp_mt)

// ============================================================================
// 数据结构
// ============================================================================

type StructurePoint
    int bar_idx
    float price
    bool is_high

// 短期结构点
var array<StructurePoint> st_points = array.new<StructurePoint>()
// 短期高点索引列表（在st_points中的索引）
var array<int> st_high_indices = array.new<int>()
// 短期低点索引列表
var array<int> st_low_indices = array.new<int>()

// 中期结构点
var array<StructurePoint> mt_points = array.new<StructurePoint>()

// ============================================================================
// 短期高低点检测 (3根K线 pivot)
// ============================================================================

var bool last_was_high = false

bool is_high = false
bool is_low = false

is_high := high[1] > high[0] and high[1] > high[2]
is_low := low[1] < low[0] and low[1] < low[2]

// 处理同时满足高低点的情况
if is_high and is_low
    if last_was_high
        is_high := false
    else
        is_low := false

// 记录短期结构点 - 高点只能连低点，低点只能连高点
// 连续高点：保留最高的；连续低点：保留最低的
if is_high
    if array.size(st_points) == 0 or not last_was_high
        // 第一个点或上一个点是低点 → 添加高点
        StructurePoint new_pt = StructurePoint.new(bar_index - 1, high[1], true)
        array.push(st_points, new_pt)
        array.push(st_high_indices, array.size(st_points) - 1)
        last_was_high := true
    else
        // 连续高点 → 比较并保留更高的
        StructurePoint old_pt = array.get(st_points, array.size(st_points) - 1)
        if high[1] > old_pt.price
            StructurePoint new_pt = StructurePoint.new(bar_index - 1, high[1], true)
            array.set(st_points, array.size(st_points) - 1, new_pt)

else if is_low
    if array.size(st_points) == 0 or last_was_high
        // 第一个点或上一个点是高点 → 添加低点
        StructurePoint new_pt = StructurePoint.new(bar_index - 1, low[1], false)
        array.push(st_points, new_pt)
        array.push(st_low_indices, array.size(st_points) - 1)
        last_was_high := false
    else
        // 连续低点 → 比较并保留更低的
        StructurePoint old_pt = array.get(st_points, array.size(st_points) - 1)
        if low[1] < old_pt.price
            StructurePoint new_pt = StructurePoint.new(bar_index - 1, low[1], false)
            array.set(st_points, array.size(st_points) - 1, new_pt)

// ============================================================================
// 中期高低点检测
// ============================================================================

// 中期高点：左边有更低的短期高点，右边也有更低的短期高点
// 中期低点：左边有更高的短期低点，右边也有更高的短期低点

var bool mt_last_was_high = false

// 检测是否有新的中期高点和中期低点
bool is_mt_high = false
StructurePoint mt_high_pt = StructurePoint.new(0, 0.0, true)

bool is_mt_low = false
StructurePoint mt_low_pt = StructurePoint.new(0, 0.0, false)

// 检测中期高点
if array.size(st_high_indices) >= 3
    int mid_idx = array.get(st_high_indices, array.size(st_high_indices) - 2)
    int left_idx = array.get(st_high_indices, array.size(st_high_indices) - 3)
    int right_idx = array.get(st_high_indices, array.size(st_high_indices) - 1)

    StructurePoint mid_pt = array.get(st_points, mid_idx)
    StructurePoint left_pt = array.get(st_points, left_idx)
    StructurePoint right_pt = array.get(st_points, right_idx)

    // 中期高点：中间的比两边都高
    if mid_pt.price > left_pt.price and mid_pt.price > right_pt.price
        // 检查是否已存在
        bool exists = false
        if array.size(mt_points) > 0
            for i = 0 to array.size(mt_points) - 1
                StructurePoint mt_pt = array.get(mt_points, i)
                if mt_pt.bar_idx == mid_pt.bar_idx and mt_pt.is_high
                    exists := true
                    break
        if not exists
            is_mt_high := true
            mt_high_pt := mid_pt

// 检测中期低点
if array.size(st_low_indices) >= 3
    int mid_idx = array.get(st_low_indices, array.size(st_low_indices) - 2)
    int left_idx = array.get(st_low_indices, array.size(st_low_indices) - 3)
    int right_idx = array.get(st_low_indices, array.size(st_low_indices) - 1)

    StructurePoint mid_pt = array.get(st_points, mid_idx)
    StructurePoint left_pt = array.get(st_points, left_idx)
    StructurePoint right_pt = array.get(st_points, right_idx)

    // 中期低点：中间的比两边都低
    if mid_pt.price < left_pt.price and mid_pt.price < right_pt.price
        bool exists = false
        if array.size(mt_points) > 0
            for i = 0 to array.size(mt_points) - 1
                StructurePoint mt_pt = array.get(mt_points, i)
                if mt_pt.bar_idx == mid_pt.bar_idx and not mt_pt.is_high
                    exists := true
                    break
        if not exists
            is_mt_low := true
            mt_low_pt := mid_pt

// 处理同时满足中期高低点的情况
// 与短期结构相同：只保留一个，确保高低交替
if is_mt_high and is_mt_low
    if mt_last_was_high
        is_mt_high := false  // 上一个是高点 → 保留低点
    else
        is_mt_low := false  // 上一个是低点 → 保留高点

// 记录中期结构点
// 必须同时满足两个条件：
// 1. 类型交替（高点连低点，低点连高点）
// 2. 时间顺序（新点的 bar_idx 必须在上一个点之后）
if is_mt_high
    if array.size(mt_points) == 0
        // 第一个点 → 添加
        array.push(mt_points, mt_high_pt)
        mt_last_was_high := true
    else
        StructurePoint last_pt = array.get(mt_points, array.size(mt_points) - 1)
        if not mt_last_was_high and mt_high_pt.bar_idx > last_pt.bar_idx
            // 上一个是低点，且新点时间更晚 → 添加高点
            array.push(mt_points, mt_high_pt)
            mt_last_was_high := true
        else if mt_last_was_high and mt_high_pt.bar_idx > last_pt.bar_idx
            // 连续高点 → 比较并保留更高的
            if mt_high_pt.price > last_pt.price
                array.set(mt_points, array.size(mt_points) - 1, mt_high_pt)

else if is_mt_low
    if array.size(mt_points) == 0
        // 第一个点 → 添加
        array.push(mt_points, mt_low_pt)
        mt_last_was_high := false
    else
        StructurePoint last_pt = array.get(mt_points, array.size(mt_points) - 1)
        if mt_last_was_high and mt_low_pt.bar_idx > last_pt.bar_idx
            // 上一个是高点，且新点时间更晚 → 添加低点
            array.push(mt_points, mt_low_pt)
            mt_last_was_high := false
        else if not mt_last_was_high and mt_low_pt.bar_idx > last_pt.bar_idx
            // 连续低点 → 比较并保留更低的
            if mt_low_pt.price < last_pt.price
                array.set(mt_points, array.size(mt_points) - 1, mt_low_pt)

// ============================================================================
// 绘图
// ============================================================================

var array<line> drawn_lines = array.new<line>()

if barstate.islast
    // 删除旧线段
    if array.size(drawn_lines) > 0
        for i = 0 to array.size(drawn_lines) - 1
            line.delete(array.get(drawn_lines, i))
        array.clear(drawn_lines)

    // 线型转换
    string st_line_style = st_style == "虚线" ? line.style_dashed : st_style == "点线" ? line.style_dotted : line.style_solid
    string mt_line_style = mt_style == "虚线" ? line.style_dashed : mt_style == "点线" ? line.style_dotted : line.style_solid

    int max_hist_offset = math.min(400, bar_index)

    // ========== 绘制短期结构 ==========
    if show_st and array.size(st_points) >= 2
        int n = array.size(st_points)
        int max_lines = 200
        int start_idx = math.max(1, n - max_lines)

        for i = start_idx to n - 1
            StructurePoint pt1 = array.get(st_points, i - 1)
            StructurePoint pt2 = array.get(st_points, i)

            // 检查两点都在历史缓冲区内
            if bar_index - pt1.bar_idx < max_hist_offset and bar_index - pt2.bar_idx < max_hist_offset
                line ln = line.new(pt1.bar_idx, pt1.price, pt2.bar_idx, pt2.price,
                         color=st_color, width=st_width, style=st_line_style)
                array.push(drawn_lines, ln)

    // ========== 绘制中期结构 ==========
    if show_mt and array.size(mt_points) >= 2
        // 按bar_idx排序
        int mt_n = array.size(mt_points)
        for i = 0 to mt_n - 2
            for j = i + 1 to mt_n - 1
                StructurePoint pti = array.get(mt_points, i)
                StructurePoint ptj = array.get(mt_points, j)
                if ptj.bar_idx < pti.bar_idx
                    array.set(mt_points, i, ptj)
                    array.set(mt_points, j, pti)

        // 限制绘制数量，并确保在历史缓冲区内
        int mt_start = 1
        for i = 1 to mt_n - 1
            StructurePoint pt = array.get(mt_points, i)
            if bar_index - pt.bar_idx < max_hist_offset
                mt_start := i
                break

        for i = mt_start to mt_n - 1
            StructurePoint pt1 = array.get(mt_points, i - 1)
            StructurePoint pt2 = array.get(mt_points, i)

            if bar_index - pt1.bar_idx < max_hist_offset and bar_index - pt2.bar_idx < max_hist_offset
                line ln = line.new(pt1.bar_idx, pt1.price, pt2.bar_idx, pt2.price,
                         color=mt_color, width=mt_width, style=mt_line_style)
                array.push(drawn_lines, ln)
