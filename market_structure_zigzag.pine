//@version=6
indicator("Market Structure Zigzag", overlay=true, max_lines_count=500)

// ============================================================================
// 输入设置
// ============================================================================

grp_line = "线段样式"
line_color = input.color(color.new(color.green, 0), "线段颜色", group=grp_line)
transparency = input.int(0, "透明度", minval=0, maxval=100, group=grp_line)
line_width = input.int(2, "线宽", minval=1, maxval=10, group=grp_line)

// ============================================================================
// 数据结构
// ============================================================================

type StructurePoint
    int bar_idx
    float price
    bool is_high

var array<StructurePoint> points = array.new<StructurePoint>()

// ============================================================================
// 短期高低点检测 (3根K线 pivot)
// ============================================================================

var bool last_was_high = false

bool is_high = false
bool is_low = false

is_high := high[1] > high[0] and high[1] > high[2]
is_low := low[1] < low[0] and low[1] < low[2]

// 处理同时满足高低点的情况
if is_high and is_low
    if last_was_high
        is_high := false
    else
        is_low := false

// 记录结构点 - 高点只能连低点，低点只能连高点
// 连续高点：保留最高的；连续低点：保留最低的
if is_high
    if array.size(points) == 0 or not last_was_high
        // 第一个点或上一个点是低点 → 添加高点
        StructurePoint new_pt = StructurePoint.new(bar_index - 1, high[1], true)
        array.push(points, new_pt)
        last_was_high := true
    else
        // 连续高点 → 比较并保留更高的
        StructurePoint old_pt = array.get(points, array.size(points) - 1)
        if high[1] > old_pt.price
            StructurePoint new_pt = StructurePoint.new(bar_index - 1, high[1], true)
            array.set(points, array.size(points) - 1, new_pt)

else if is_low
    if array.size(points) == 0 or last_was_high
        // 第一个点或上一个点是高点 → 添加低点
        StructurePoint new_pt = StructurePoint.new(bar_index - 1, low[1], false)
        array.push(points, new_pt)
        last_was_high := false
    else
        // 连续低点 → 比较并保留更低的
        StructurePoint old_pt = array.get(points, array.size(points) - 1)
        if low[1] < old_pt.price
            StructurePoint new_pt = StructurePoint.new(bar_index - 1, low[1], false)
            array.set(points, array.size(points) - 1, new_pt)

// ============================================================================
// 绘图
// ============================================================================

var array<line> drawn_lines = array.new<line>()

if barstate.islast and array.size(points) >= 2
    // 删除旧线段
    if array.size(drawn_lines) > 0
        for i = 0 to array.size(drawn_lines) - 1
            line.delete(array.get(drawn_lines, i))
        array.clear(drawn_lines)

    int n = array.size(points)
    int max_lines = 200
    int start_idx = math.max(1, n - max_lines)

    color draw_color = color.new(line_color, transparency)

    // 绘制连接线
    for i = start_idx to n - 1
        StructurePoint pt1 = array.get(points, i - 1)
        StructurePoint pt2 = array.get(points, i)

        line ln = line.new(pt1.bar_idx, pt1.price, pt2.bar_idx, pt2.price,
                 color=draw_color, width=line_width)
        array.push(drawn_lines, ln)
