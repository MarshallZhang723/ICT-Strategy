//@version=6
indicator("Trading Day Separator", overlay=true, max_lines_count=500)

// ─────────────────────────────────────────────
// 输入设置
// ─────────────────────────────────────────────

string GDAY     = "══ 交易日分割线 ══"
bool   showDay  = input.bool(true,     "显示交易日分割线", group = GDAY)
color  colDay   = input.color(#546e7a, "分割线颜色",     group = GDAY)
string dayStyle = input.string("虚线", "分割线样式",     options = ["实线", "虚线", "点线"], group = GDAY)
int    dayWidth = input.int(1,         "分割线宽度",     minval = 1, maxval = 4, group = GDAY)

bool   showWkd  = input.bool(true,     "显示星期文字",   group = GDAY)
color  colWkd   = input.color(#78909c, "星期文字颜色",   group = GDAY)
string wkdSize  = input.string("small","星期文字大小",   options = ["tiny", "small", "normal", "large"], group = GDAY)

// ─────────────────────────────────────────────
// 交易日分割线检测（基于纽约时间 0 点）
// ─────────────────────────────────────────────

int nyHour = hour(time, "America/New_York")
int nyHour_prev = nyHour[1]
// 检测纽约时间进入 0 点（小时变成 0 表示新的一天开始）
bool is_new_ny_day = na(nyHour_prev) ? false : nyHour == 0 and nyHour_prev != 0

// 记录交易日分割点和对应的星期几
var array<int> day_separators = array.new<int>()
var array<string> day_names = array.new<string>()

if is_new_ny_day
    array.push(day_separators, bar_index)
    int ny_day = dayofweek(ny_time)
    string day_name = ny_day == dayofweek.monday ? "Mon" :
                      ny_day == dayofweek.tuesday ? "Tue" :
                      ny_day == dayofweek.wednesday ? "Wed" :
                      ny_day == dayofweek.thursday ? "Thu" :
                      ny_day == dayofweek.friday ? "Fri" :
                      ny_day == dayofweek.saturday ? "Sat" : "Sun"
    array.push(day_names, day_name)

// ─────────────────────────────────────────────
// 绘图
// ─────────────────────────────────────────────

var array<line> drawn_lines = array.new<line>()
var array<label> day_labels = array.new<label>()

// 文字大小转换
string wkdSizeVal = wkdSize == "tiny" ? size.tiny : wkdSize == "small" ? size.small : wkdSize == "normal" ? size.normal : size.large

if barstate.islast
    // 删除旧线段和标签
    if array.size(drawn_lines) > 0
        for i = 0 to array.size(drawn_lines) - 1
            line.delete(array.get(drawn_lines, i))
        array.clear(drawn_lines)

    if array.size(day_labels) > 0
        for i = 0 to array.size(day_labels) - 1
            label.delete(array.get(day_labels, i))
        array.clear(day_labels)

    // 线型转换
    string dayStyleStr = dayStyle == "虚线" ? line.style_dashed : dayStyle == "点线" ? line.style_dotted : line.style_solid

    int max_hist_offset = 900

    // 绘制交易日分割线和星期标签
    if array.size(day_separators) >= 1
        int prev_sep = na

        // 使用最近 N 根 K 线的最低价作为标签 y 位置
        int lookback = math.min(500, bar_index)
        float fixed_y = ta.lowest(low, lookback)

        for i = 0 to array.size(day_separators) - 1
            int sep_bar = array.get(day_separators, i)
            string sep_day_name = array.get(day_names, i)

            // 只绘制在缓冲区内的分割线
            if bar_index - sep_bar < max_hist_offset
                // 画分割线
                if showDay
                    line day_ln = line.new(sep_bar, high, sep_bar, low,
                             xloc = xloc.bar_index, extend = extend.both,
                             color = colDay, width = dayWidth, style = dayStyleStr)
                    array.push(drawn_lines, day_ln)

                // 添加星期标签（在两个分割线之间的中间位置）
                if showWkd and not na(prev_sep) and not na(fixed_y)
                    int mid_bar = math.round((prev_sep + sep_bar) / 2)
                    label day_lbl = label.new(mid_bar, fixed_y,
                             text = sep_day_name,
                             xloc = xloc.bar_index,
                             color = color.new(color.gray, 100),
                             style = label.style_label_up,
                             textcolor = colWkd,
                             size = wkdSizeVal)
                    label.set_yloc(day_lbl, yloc.price)
                    label.set_y(day_lbl, fixed_y)
                    array.push(day_labels, day_lbl)

            prev_sep := sep_bar

        // 为最后一个交易日添加标签
        if showWkd and not na(prev_sep) and not na(fixed_y) and bar_index - prev_sep < max_hist_offset
            int mid_bar = math.round((prev_sep + bar_index) / 2)
            string current_day_name = dayofweek(ny_time) == dayofweek.monday ? "Mon" :
                                      dayofweek(ny_time) == dayofweek.tuesday ? "Tue" :
                                      dayofweek(ny_time) == dayofweek.wednesday ? "Wed" :
                                      dayofweek(ny_time) == dayofweek.thursday ? "Thu" :
                                      dayofweek(ny_time) == dayofweek.friday ? "Fri" :
                                      dayofweek(ny_time) == dayofweek.saturday ? "Sat" : "Sun"
            label day_lbl = label.new(mid_bar, fixed_y,
                     text = current_day_name,
                     xloc = xloc.bar_index,
                     color = color.new(color.gray, 100),
                     style = label.style_label_up,
                     textcolor = colWkd,
                     size = wkdSizeVal)
            label.set_yloc(day_lbl, yloc.price)
            label.set_y(day_lbl, fixed_y)
            array.push(day_labels, day_lbl)
